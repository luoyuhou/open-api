// 测试环境专用 Prisma Schema - 使用 SQLite
// 此文件包含所有生产环境的表模型,但移除了 MySQL 特定的类型声明
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model user {
  id          Int       @id @default(autoincrement())
  user_id     String    @unique
  status      Int
  first_name  String
  last_name   String
  email       String?
  phone       String    @unique
  gender      Int       @default(0)
  avatar      String?
  bio         String?
  create_date DateTime? @default(now())
  update_date DateTime? @default(now())
}

model user_signin_history {
  id          Int       @id @default(autoincrement())
  user_id     String
  ip          String?
  useragent   String?
  source      Int
  create_date DateTime? @default(now())
  update_date DateTime? @default(now())
}

model user_signin_password {
  id                 Int       @id @default(autoincrement())
  user_id            String    @unique
  salt               String
  password           String
  failed_login_times Int       @default(0)
  locked_date        DateTime?
  create_date        DateTime? @default(now())
  update_date        DateTime? @default(now())
}

model user_signin_wechat {
  id          Int       @id @default(autoincrement())
  openid      String    @unique
  user_id     String    @unique
  create_date DateTime? @default(now())
  update_date DateTime? @default(now())
}

model store {
  id            Int       @id @default(autoincrement())
  store_id      String    @unique
  id_code       String
  id_name       String
  user_id       String
  store_name    String
  phone         String
  province      String
  city          String
  area          String
  town          String
  address       String
  wechat_qr_url String?
  alipay_qr_url String?
  status        Int       @default(0)
  create_date   DateTime? @default(now())
  update_date   DateTime? @default(now())
}


model store_history {
  id             Int       @id @default(autoincrement())
  store_id       String
  action_type    Int
  action_content String
  payload        String?
  action_user_id String
  action_date    DateTime
  create_date    DateTime? @default(now())
  update_date    DateTime? @default(now())
}

model user_address {
  id              Int       @id @default(autoincrement())
  user_address_id String    @unique
  user_id         String
  recipient       String
  phone           String
  province        String
  city            String
  area            String
  town            String
  address         String
  is_default      Boolean   @default(false)
  tag             String?
  status          Boolean   @default(true)
  create_date     DateTime? @default(now())
  update_date     DateTime? @default(now())
}

model category_goods {
  id          Int       @id @default(autoincrement())
  category_id String    @unique
  store_id    String
  pid         String?
  rank        Int       @default(0)
  name        String
  status      Int
  create_date DateTime? @default(now())
  update_date DateTime? @default(now())

  @@unique([store_id, name])
}

model store_goods {
  id          Int       @id @default(autoincrement())
  goods_id    String    @unique
  store_id    String
  category_id String
  name        String
  description String?
  status      Int
  create_date DateTime? @default(now())
  update_date DateTime? @default(now())

  @@unique([store_id, category_id, name])
}

model store_goods_version {
  id             Int       @id @default(autoincrement())
  version_id     String    @unique
  goods_id       String
  version_number String?
  bar_code       String?
  count          Int
  price          Int
  unit_name      String
  supplier       String?
  status         Int
  create_date    DateTime? @default(now())
  update_date    DateTime? @default(now())

  @@unique([goods_id, unit_name, version_number])
  @@unique([goods_id, unit_name, bar_code])
}

model user_order {
  id             Int       @id @default(autoincrement())
  order_id       String    @unique
  user_id        String
  store_id       String
  status         Int
  stage          Int
  payment_method String    @default("cod")
  payment_channel String?
  pay_status     Int       @default(0)
  paid_at        DateTime?
  pay_proof_url  String?
  recipient      String
  money          Int
  phone          String
  province       String
  city           String
  area           String
  town           String
  address        String
  delivery_date  DateTime
  create_date    DateTime? @default(now())
  update_date    DateTime? @default(now())
}

model user_order_info {
  id               Int       @id @default(autoincrement())
  order_info_id    String    @unique
  order_id         String
  goods_id         String
  goods_name       String
  goods_version_id String
  count            Int
  price            Int
  create_date      DateTime? @default(now())
  update_date      DateTime? @default(now())
}

model user_order_action {
  id              Int       @id @default(autoincrement())
  order_action_id String    @unique
  user_id         String
  order_id        String
  status          Int
  create_date     DateTime? @default(now())
  update_date     DateTime? @default(now())
}

model province {
  id       Int    @id @default(autoincrement())
  code     String
  name     String
  province String
  city     String
  area     String
  town     String
}

model store_apply {
  id                Int       @id @default(autoincrement())
  store_id          String
  type              Int
  applicant_user_id String
  applicant_date    DateTime
  applicant_summary String
  applicant_content String
  status            Int       @default(0)
  replient_user_id  String?
  replient_date     DateTime?
  replient_content  String?
  create_date       DateTime? @default(now())
  update_date       DateTime? @default(now())
}

model auth {
  id          Int       @id @default(autoincrement())
  pid         String    @default("0")
  auth_id     String    @unique
  side        Int
  path        String
  method      String?
  status      Int
  create_date DateTime? @default(now())
  update_date DateTime? @default(now())

  @@unique([side, path])
}

model role {
  id          Int       @id @default(autoincrement())
  role_id     String    @unique
  role_name   String    @unique
  description String?
  create_date DateTime? @default(now())
  update_date DateTime? @default(now())
}

model user_auth {
  id          Int       @id @default(autoincrement())
  user_id     String    @unique
  is_admin    Boolean
  status      Int
  create_date DateTime? @default(now())
  update_date DateTime? @default(now())
}

model user_role {
  id          Int       @id @default(autoincrement())
  role_id     String
  user_id     String
  status      Int
  create_date DateTime? @default(now())
  update_date DateTime? @default(now())

  @@unique([user_id, role_id])
}

model auth_role {
  id          Int       @id @default(autoincrement())
  auth_id     String
  role_id     String
  status      Int
  create_date DateTime? @default(now())
  update_date DateTime? @default(now())

  @@unique([role_id, auth_id])
}

model user_fetch {
  id          Int       @id @default(autoincrement())
  user_id     String
  source      Int
  url         String
  method      String
  create_date DateTime? @default(now())
  update_date DateTime? @default(now())
}

model report_daily_user_fetch {
  id          Int       @id @default(autoincrement())
  user_id     String
  times       Int
  use_time    Int
  record_date DateTime
  create_date DateTime? @default(now())
  update_date DateTime? @default(now())
}

model home_banner {
  id          Int       @id @default(autoincrement())
  banner_id   String    @unique
  title       String
  description String?
  image_url   String
  width       Int?
  height      Int?
  sort        Int       @default(0)
  status      Int       @default(1)
  create_date DateTime? @default(now())
  update_date DateTime? @default(now())
}

model file {
  id          Int      @id @default(autoincrement())
  file_name   String?
  hash        String   @unique
  url         String
  create_date DateTime @default(now())
  update_date DateTime @default(now())
}

model chat_group {
  id          Int       @id @default(autoincrement())
  group_id    String    @unique
  name        String
  owner_id    String
  type        Int
  status      Int       @default(1)
  create_date DateTime? @default(now())
  update_date DateTime? @default(now())
}

model chat_group_user {
  id          Int       @id @default(autoincrement())
  group_id    String
  user_id     String
  role        Int       @default(0)
  create_date DateTime? @default(now())
  update_date DateTime? @default(now())

  @@unique([group_id, user_id])
}

model store_rating {
  id          Int       @id @default(autoincrement())
  store_id    String    @unique
  rating      Float     @default(0)
  order_count Int       @default(0)
  avg_star    Float     @default(0)
  updated_at  DateTime? @default(now())
}

model user_favorite_store {
  id          Int       @id @default(autoincrement())
  user_id     String
  store_id    String
  create_date DateTime? @default(now())
  update_date DateTime? @default(now())

  @@unique([user_id, store_id])
}

model user_store_browse_history {
  id          Int       @id @default(autoincrement())
  user_id     String
  store_id    String
  visit_date  DateTime
  create_date DateTime? @default(now())
  update_date DateTime? @default(now())

  @@unique([user_id, store_id])
}

model user_feedback {
  id          Int       @id @default(autoincrement())
  user_id     String
  title       String
  content     String
  category    String?
  status      Int       @default(0)
  create_date DateTime? @default(now())
  update_date DateTime? @default(now())
}

model user_feedback_attachment {
  id          Int       @id @default(autoincrement())
  feedback_id Int
  url         String
  type        Int       @default(1)
  description String?
  create_date DateTime? @default(now())
}

model user_feedback_comment {
  id          Int       @id @default(autoincrement())
  feedback_id Int
  user_id     String
  content     String
  parent_id   Int?
  create_date DateTime? @default(now())
  update_date DateTime? @default(now())
}

model report_store_daily_order {
  id           Int       @id @default(autoincrement())
  store_id     String
  total_orders Int
  total_amount Int
  record_date  DateTime
  create_date  DateTime? @default(now())
  update_date  DateTime? @default(now())

  @@index([record_date])
  @@index([store_id])
}

model report_platform_daily_order {
  id           Int       @id @default(autoincrement())
  total_orders Int
  total_amount Int
  record_date  DateTime
  create_date  DateTime? @default(now())
  update_date  DateTime? @default(now())

  @@index([record_date])
}

model report_store_daily_goods {
  id               Int       @id @default(autoincrement())
  store_id         String
  goods_id         String
  goods_version_id String
  goods_name       String
  total_count      Int
  total_amount     Int
  record_date      DateTime
  create_date      DateTime? @default(now())
  update_date      DateTime? @default(now())

  @@index([record_date])
  @@index([store_id, goods_id])
  @@index([store_id, goods_id, goods_version_id])
}

model store_service_plan {
  id                         Int                          @id @default(autoincrement())
  name                       String
  description                String?
  monthly_fee                Int
  is_active                  Boolean                      @default(true)
  create_date                DateTime                     @default(now())
  update_date                DateTime                     @default(now())
  store_service_contract     store_service_contract[]
  store_service_subscription store_service_subscription[]
}

model store_service_subscription {
  id          Int                     @id @default(autoincrement())
  store_id    String
  plan_id     Int
  start_date  DateTime
  end_date    DateTime
  status      Int                     @default(1)
  create_date DateTime                @default(now())
  update_date DateTime                @default(now())
  contract_id Int?
  invoice     store_service_invoice[]
  contract    store_service_contract? @relation(fields: [contract_id], references: [id], onDelete: Restrict, onUpdate: Restrict)
  plan        store_service_plan      @relation(fields: [plan_id], references: [id], onUpdate: Restrict)
  
  @@index([store_id])
  @@index([plan_id])
  @@index([contract_id])
}

model store_service_invoice {
  id              Int                        @id @default(autoincrement())
  subscription_id Int
  month           String
  start_date      DateTime
  end_date        DateTime
  amount          Int
  status          Int                        @default(0)
  due_date        DateTime
  paid_at         DateTime?
  create_date     DateTime                   @default(now())
  update_date     DateTime                   @default(now())
  subscription    store_service_subscription @relation(fields: [subscription_id], references: [id], onUpdate: Restrict)
  payment         store_service_payment[]
  
  @@index([subscription_id, month])
}

model store_service_payment {
  id          Int                   @id @default(autoincrement())
  invoice_id  Int
  amount      Int
  method      String
  remark      String?
  paid_at     DateTime              @default(now())
  create_date DateTime              @default(now())
  invoice     store_service_invoice @relation(fields: [invoice_id], references: [id], onUpdate: Restrict)
  
  @@index([invoice_id])
}

model store_service_contract {
  id                 Int                          @id @default(autoincrement())
  contract_no        String                       @unique
  store_id           String
  plan_id            Int
  start_date         DateTime
  end_date           DateTime
  status             Int                          @default(1)
  sign_type          Int
  signed_at          DateTime?
  total_amount       Int
  file_url           String?
  create_date        DateTime                     @default(now())
  update_date        DateTime                     @default(now())
  store_service_plan store_service_plan           @relation(fields: [plan_id], references: [id], onUpdate: Restrict)
  subscription       store_service_subscription[]
  
  @@index([store_id])
  @@index([plan_id])
}